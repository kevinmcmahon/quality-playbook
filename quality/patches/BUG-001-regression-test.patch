+#!/bin/bash
+# Generated by Quality Playbook v1.4.0
+# Regression test for BUG-001: tdd_verified vs verified in Example 1 summary
+# SKILL.md line 127 uses "tdd_verified" but normative text (line 1394) requires "verified"
+set -euo pipefail
+SKILL="$(cd "$(dirname "$0")/.." && pwd)/SKILL.md"
+# The first canonical example (lines 110-130) must use "verified", not "tdd_verified"
+count=$(sed -n '110,130p' "$SKILL" | grep -c '"tdd_verified"' || true)
+if [ "$count" -gt 0 ]; then
+    echo "FAIL: Example 1 uses 'tdd_verified' instead of 'verified' at line 127"
+    exit 1
+fi
+echo "PASS: Example 1 correctly uses 'verified'"
