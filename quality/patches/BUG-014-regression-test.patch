+# ──────────────────────────────────────────────────────────────────────
+# BUG-014: #### BUG-NNN headings invisible to all detection patterns
+# Skip guard: Remove this block to run the test (unskip after applying
+# quality/patches/BUG-014-fix.patch)
+# ──────────────────────────────────────────────────────────────────────
+
+test_bug_014_four_hash_headings_invisible() {
+    # BUG-014: BUGS.md with #### BUG-NNN headings escapes all detection
+    # [Spec basis: SKILL.md line 1611, canonical heading format]
+    # Expected: gate detects or reports #### BUG-NNN headings
+    # Actual (bug): headings are invisible, bug_count=0
+    local dir
+    dir=$(setup_test_dir)
+    create_passing_artifacts "$dir"
+    # Create BUGS.md with four-hash heading
+    echo -e "# Confirmed Bugs\n\n#### BUG-001: Test bug with four hashes\n\n**File:** test.sh:1\n**Severity:** LOW" > "${dir}/quality/BUGS.md"
+
+    # Run the gate and capture output
+    local output exit_code=0
+    output=$(bash "${GATE}" "$dir" 2>&1) || exit_code=$?
+
+    # Check if the gate detected any bugs at all
+    if echo "$output" | grep -q 'bug.*heading\|heading.*BUG\|BUG-NNN\|1 bug'; then
+        pass "BUG-014: Gate detects four-hash BUG headings"
+    elif echo "$output" | grep -q 'Zero bugs\|tdd-results.json not required'; then
+        xfail "BUG-014: Gate treats #### BUG-001 as zero bugs (invisible heading format)"
+    else
+        xfail "BUG-014: Gate does not detect #### BUG-NNN heading format (bug_count=0)"
+    fi
+    cleanup "$dir"
+}
+
