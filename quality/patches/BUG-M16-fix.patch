--- a/quality_gate.sh
+++ b/quality_gate.sh
@@ -122,8 +122,11 @@ check_repo() {
     # Functional test file — check all SKILL.md-documented naming patterns
-    if ls ${q}/test_functional.* ${q}/FunctionalSpec.* ${q}/FunctionalTest.* ${q}/functional.test.* &>/dev/null 2>&1; then
-        pass "functional test file exists"
-    else
-        fail "functional test file missing (test_functional.*, FunctionalSpec.*, FunctionalTest.*, functional.test.*)"
-    fi
+    if find "${q}" -maxdepth 1 \( \
+           -name "test_functional.*" \
+           -o -name "FunctionalSpec.*" \
+           -o -name "FunctionalTest.*" \
+           -o -name "functional.test.*" \
+       \) -print -quit 2>/dev/null | grep -q .; then
+        pass "functional test file exists"
+    else
+        fail "functional test file missing (test_functional.*, FunctionalSpec.*, FunctionalTest.*, functional.test.*)"
+    fi

Rationale: Replaces the nullglob-vulnerable `ls`-glob with a `find -print -quit`
pattern that is immune to nullglob. If no matching file exists, `find` produces
no output; `grep -q .` then exits 1 and the gate correctly reports failure.
This matches the find-based detection pattern already used at lines 449-454 and
is consistent with fixes for BUG-M8 (lines 152-153,331,567-568,595),
BUG-M12 (line 479), and BUG-M13 (line 143).
