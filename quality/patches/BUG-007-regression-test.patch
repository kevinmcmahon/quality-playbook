--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -end,0 +end,18 @@
+
+# BUG-007: Version detection path asymmetry between global and per-repo checks
+# Global detection (lines 59-67) tries 6 paths; per-repo stamp check (lines 581-586) tries 4.
+# The per-repo check is missing ${SCRIPT_DIR}/../SKILL.md and ${SCRIPT_DIR}/SKILL.md.
+test_bug_007_version_path_asymmetry() {
+    # Extract path counts from both sections
+    local global_paths per_repo_paths
+    global_paths=$(sed -n '61p' quality_gate.sh | grep -oE '"[^"]*SKILL\.md"' | wc -l | tr -d ' ')
+    per_repo_paths=$(sed -n '581p' quality_gate.sh | grep -oE '"[^"]*SKILL\.md"' | wc -l | tr -d ' ')
+
+    if [ "$global_paths" -ne "$per_repo_paths" ]; then
+        echo "XFAIL: BUG-007 confirmed — global version detection has ${global_paths} paths, per-repo has ${per_repo_paths}"
+        return 0
+    else
+        echo "PASS: BUG-007 fixed — path counts are equal (${global_paths})"
+        return 0
+    fi
+}
