--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -0,0 +1,42 @@
+# ---------------------------------------------------------------------------
+# BUG-H17: BUG-[0-9]+ regex never matches severity-prefix IDs (BUG-H1 format)
+# ---------------------------------------------------------------------------
+: "${BUG_SKIP_H17:=1}"
+test_BUG_H17_bug_id_regex_bypasses_severity_prefix() {
+    if [ "$BUG_SKIP_H17" -ne 0 ]; then
+        echo "SKIP: test_BUG_H17_bug_id_regex_bypasses_severity_prefix (BUG_SKIP_H17=${BUG_SKIP_H17})"
+        return 77
+    fi
+    echo "TEST: test_BUG_H17_bug_id_regex_bypasses_severity_prefix"
+    local gate="/Users/andrewstellman/tmp/QFB-bootstrap/quality_gate.sh"
+    # Direct proof: the regex BUG-[0-9]+ does not match BUG-H1
+    local match
+    match=$(echo '### BUG-H1' | grep -cE '^### BUG-[0-9]+' || true)
+    if [ "$match" -eq 0 ]; then
+        echo "  BUG CONFIRMED: regex '^### BUG-[0-9]+' returns 0 matches for '### BUG-H1'"
+        echo "  Consequence: bug_count=0 for any BUGS.md using severity-prefix IDs"
+        echo "  Gate then skips ALL TDD/patch/writeup validation (lines 223,309,564,592)"
+        # Also verify the gate actually uses this regex
+        if grep -qE "grep -cE '\^### BUG-\[0-9\]\+'" "$gate" || \
+           grep -q "BUG-\[0-9\]" "$gate"; then
+            echo "  Gate confirmed to use BUG-[0-9]+ regex — bug is present in unpatched code"
+        fi
+        return 1  # FAILS on unpatched code (red phase)
+    else
+        echo "  BUG FIXED: regex now matches severity-prefix IDs (BUG-H1 format matches)"
+        return 0
+    fi
+}
+
+# Add to run_test calls (in else branch):
+#    run_test test_BUG_H17_bug_id_regex_bypasses_severity_prefix

Rationale: quality_gate.sh uses regex '^### BUG-[0-9]+' to count bugs in BUGS.md.
This regex requires a pure numeric suffix (BUG-001, BUG-123) and never matches
the severity-prefix IDs (BUG-H1, BUG-M3, BUG-L6) generated by QFB Phase 3.
The result: bug_count=0, and all four downstream validation sections
(lines 223, 309, 564, 592) are skipped — the gate provides zero artifact
validation for every standard QFB self-audit run.
