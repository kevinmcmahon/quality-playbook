+#!/bin/bash
+# Generated by Quality Playbook v1.4.0
+# Regression test for BUG-003: eval injection with user-supplied directory paths
+# Spec basis: quality_gate.sh lines 439-448
+
+set -uo pipefail
+SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
+REPO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
+GATE="${REPO_DIR}/quality_gate.sh"
+
+# Source-inspection test: verify eval is not used with user-supplied repo_dir
+eval_with_user_input=$(grep -c 'eval.*\${repo_dir}\|eval.*repo_dir' "${GATE}" 2>/dev/null || echo 0)
+
+if [ "$eval_with_user_input" -gt 0 ]; then
+    echo "FAIL: quality_gate.sh uses eval with user-supplied repo_dir variable (${eval_with_user_input} occurrences)"
+    exit 1
+else
+    echo "PASS: quality_gate.sh does not use eval with user-supplied paths"
+    exit 0
+fi
