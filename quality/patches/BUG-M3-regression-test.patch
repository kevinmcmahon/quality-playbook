+# ---------------------------------------------------------------------------
+# BUG-M3: Phase 2 entry gate enforces only 6 of 12 Phase 1 checks
+#
+# The bug: Phase 2 entry gate (SKILL.md:897-904) checks for 6 section titles
+# but does not enforce checks 2, 3, 5, 8, 10, 12 from Phase 1 gate.
+# An EXPLORATION.md with correct section titles but shallow content passes.
+# Skip guard: set BUG_SKIP_M3=0 to enable (default: skip)
+# Remove this guard after applying quality/patches/BUG-M3-fix.patch
+# ---------------------------------------------------------------------------
+test_BUG_M3_phase2_gate_missing_checks() {
+    if [ "${BUG_SKIP_M3:-1}" = "1" ]; then
+        echo "  SKIP: BUG-M3 skip guard active (set BUG_SKIP_M3=0 to run)"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    local skill_md="${SKILL_MD_PATH:-SKILL.md}"
+
+    if [ ! -f "$skill_md" ]; then
+        echo "  SKIP: SKILL.md not found at $skill_md (set SKILL_MD_PATH)"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    # Phase 1 gate defines 12 checks (lines 847-862 in SKILL.md)
+    # Count the numbered checks in the Phase 1 gate section
+    local phase1_checks
+    phase1_checks=$(awk '/Phase 1 completion gate \(mandatory/,/Do not begin Phase 2/' "$skill_md" \
+        | grep -cE '^\*\*[0-9]+\.' || true)
+
+    # Phase 2 entry gate defines checks (lines 897-904 in SKILL.md)
+    # Count the numbered items in the Phase 2 entry gate section
+    local phase2_checks
+    phase2_checks=$(awk '/Phase 2 entry gate \(mandatory — HARD STOP\)/,/If the file does not exist/' "$skill_md" \
+        | grep -cE '^[0-9]+\.' || true)
+
+    # The bug: phase2_checks (6) < phase1_checks (12)
+    # A fixed Phase 2 gate would enforce all 12, or explicitly document
+    # which checks are not backstopped
+    if [ "${phase1_checks:-0}" -le "${phase2_checks:-0}" ]; then
+        echo "  Phase 2 gate enforces ${phase2_checks} checks; Phase 1 gate has ${phase1_checks}"
+        echo "  BUG FIXED: Phase 2 gate now enforces all Phase 1 checks"
+        return 0
+    else
+        echo "  BUG CONFIRMED: Phase 2 gate enforces ${phase2_checks} checks but Phase 1 gate has ${phase1_checks}"
+        echo "  Missing checks: 2 (PROGRESS.md complete), 3 (Derived Requirements), 5 (depth), 8 (FULL patterns), 10 (depth), 12 (ensemble)"
+        return 1  # Test FAILS on unpatched code (red phase)
+    fi
+}
+
 # Run tests
 echo "=== Regression Tests: quality-playbook ==="
 if [ $# -gt 0 ]; then
