 }
+
+# BUG-010: Incomplete writeups get WARN instead of FAIL
+# Spec basis: SKILL.md line 1454 says writeups are mandatory for all confirmed bugs.
+# verification.md benchmark 30 says every confirmed bug must have a writeup.
+# quality_gate.sh line 561 uses warn() instead of fail().
+test_bug_010_writeup_incomplete_warn() {
+    local line
+    line=$(sed -n '561p' quality_gate.sh)
+    if echo "$line" | grep -q 'warn'; then
+        echo "FAIL: quality_gate.sh line 561 uses warn() for incomplete writeups (should be fail())"
+        return 1
+    fi
+    return 0
+}
