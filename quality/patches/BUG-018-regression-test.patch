--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -0,0 +1,50 @@
+# Regression test for BUG-018: json_key_count false PASS masks missing per-bug fields
+# grep-based json_key_count counts string matches, not JSON keys. A bug description
+# containing a quoted field name inflates the count, masking a missing field.

+test_bug_018_json_key_count_false_pass() {
+    local gate_script="quality_gate.sh"
+    if [ ! -f "$gate_script" ]; then
+        echo "SKIP: quality_gate.sh not found"
+        return
+    fi
+
+    # Source the json_key_count function
+    # Since we can't source the whole script (it has side effects), extract the function
+    json_key_count() {
+        local file="$1" key="$2"
+        grep -c "\"${key}\"" "$file" 2>/dev/null || echo 0
+    }
+
+    # Create a tdd-results.json where:
+    # BUG-001 has all fields, and its requirement text contains "verdict"
+    # BUG-002 is missing the verdict field entirely
+    local tmpdir
+    tmpdir=$(mktemp -d)
+    cat > "$tmpdir/tdd-results.json" << 'ENDJSON'
+{
+  "schema_version": "1.1",
+  "skill_version": "1.4.0",
+  "date": "2026-04-15",
+  "project": "test",
+  "bugs": [
+    {
+      "id": "BUG-001",
+      "requirement": "REQ-014: \"verdict\" field must use canonical enum values",
+      "red_phase": "fail",
+      "green_phase": "pass",
+      "verdict": "TDD verified",
+      "fix_patch_present": true,
+      "writeup_path": "quality/writeups/BUG-001.md"
+    },
+    {
+      "id": "BUG-002",
+      "requirement": "REQ-001: Artifact enforcement",
+      "red_phase": "fail",
+      "green_phase": "pass",
+      "fix_patch_present": true,
+      "writeup_path": "quality/writeups/BUG-002.md"
+    }
+  ],
+  "summary": { "total": 2, "verified": 2, "confirmed_open": 0, "red_failed": 0, "green_failed": 0 }
+}
+ENDJSON
+
+    local count
+    count=$(json_key_count "$tmpdir/tdd-results.json" "verdict")
+    # BUG: count is 2 (one real field + one string match) but BUG-002 is missing verdict
+    # The check "count >= bug_count" (2 >= 2) would PASS incorrectly
+    [ "$count" -ge 2 ] && echo "XFAIL: json_key_count reports $count for 'verdict' — masks missing field in BUG-002"
+    rm -rf "$tmpdir"
+}
