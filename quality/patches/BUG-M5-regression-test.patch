     fi
 }

+# ---------------------------------------------------------------------------
+# BUG-M5: Phase 0b skips when previous_runs/ exists but is empty
+#
+# The bug: Phase 0b activation condition is "previous_runs/ does not exist"
+# but Phase 0a only activates when it exists AND contains artifacts.
+# When previous_runs/ exists but is empty: both phases skip with no warning.
+# Skip guard: set BUG_SKIP_M5=0 to enable (default: skip)
+# Remove this guard after applying quality/patches/BUG-M5-fix.patch
+# ---------------------------------------------------------------------------
+test_BUG_M5_phase0b_skips_on_empty_previous_runs() {
+    if [ "${BUG_SKIP_M5:-1}" = "1" ]; then
+        echo "  SKIP: BUG-M5 skip guard active (set BUG_SKIP_M5=0 to run)"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    local skill_md="${SKILL_MD_PATH:-SKILL.md}"
+
+    if [ ! -f "$skill_md" ]; then
+        echo "  SKIP: SKILL.md not found at $skill_md (set SKILL_MD_PATH)"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    # Check Phase 0a activation condition in SKILL.md
+    local phase0a_cond
+    phase0a_cond=$(grep -A2 'Phase 0:' "$skill_md" | grep -E 'previous_runs.*exists.*contains|exists.*previous_runs.*contains' || true)
+
+    # Check Phase 0b activation condition in SKILL.md
+    local phase0b_cond
+    phase0b_cond=$(grep -A3 'Phase 0b:' "$skill_md" | grep -E 'does not exist|not exist' | head -1 || true)
+
+    # The fix would require Phase 0b activation to include "OR is empty"
+    # Check if the fixed condition exists:
+    local phase0b_fixed
+    phase0b_fixed=$(grep -A5 'Phase 0b:' "$skill_md" \
+        | grep -E 'does not exist.*OR.*empty|empty.*does not exist|not exist.*OR.*no conformant|no conformant.*not exist' \
+        || true)
+
+    if [ -n "$phase0b_fixed" ]; then
+        echo "  BUG FIXED: Phase 0b activation condition includes empty-directory case"
+        echo "  Found: $phase0b_fixed"
+        return 0
+    fi
+
+    # Bug check: verify the gap exists — Phase 0b says "does not exist" without "OR is empty"
+    if echo "$phase0b_cond" | grep -q "does not exist"; then
+        echo "  BUG CONFIRMED: Phase 0b activation says 'does not exist' without 'OR is empty'"
+        echo "  Phase 0a requires: previous_runs/ exists AND contains artifacts"
+        echo "  Phase 0b requires: previous_runs/ does NOT exist"
+        echo "  Gap: empty previous_runs/ causes both to skip, no warning emitted"
+        return 1  # Test FAILS on unpatched code (red phase)
+    else
+        echo "  INCONCLUSIVE: Could not parse Phase 0b activation condition from SKILL.md"
+        echo "  Manual check required at SKILL.md lines 271-297"
+        return 1
+    fi
+}
+
 # Run tests
 echo "=== Regression Tests: quality-playbook ==="
