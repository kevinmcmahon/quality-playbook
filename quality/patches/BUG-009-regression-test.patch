 }
+
+# BUG-009: TOOLKIT.md Copilot reference installation path not in SKILL.md fallback chain
+# Spec basis: SKILL.md lines 46-53 define 4 reference resolution paths.
+# TOOLKIT.md lines 24-26 instruct Copilot users to install at .github/skills/references/
+# which is not in the 4-path fallback chain.
+test_bug_009_toolkit_copilot_path() {
+    # Check that SKILL.md's fallback chain includes .github/skills/references/
+    if ! grep -q '\.github/skills/references/' SKILL.md 2>/dev/null; then
+        # Confirm TOOLKIT.md instructs users to use this path
+        if grep -q '\.github/skills/references/' ai_context/TOOLKIT.md 2>/dev/null; then
+            echo "FAIL: TOOLKIT.md instructs Copilot reference path .github/skills/references/"
+            echo "  but SKILL.md's fallback chain (lines 48-51) does not include this path"
+            echo "  SKILL.md paths: references/, .claude/skills/quality-playbook/references/,"
+            echo "  references/ (repo root), .github/skills/quality-playbook/references/"
+            return 1
+        fi
+    fi
+    return 0
+}
