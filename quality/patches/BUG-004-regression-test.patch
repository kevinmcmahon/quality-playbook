+#!/bin/bash
+# Generated by Quality Playbook v1.4.0
+# Regression test for BUG-004: SKILL.md claims gate checks TDD log status tags
+# but quality_gate.sh only checks file existence
+set -euo pipefail
+SKILL="$(cd "$(dirname "$0")/.." && pwd)/SKILL.md"
+GATE="$(cd "$(dirname "$0")/.." && pwd)/quality_gate.sh"
+# Check if gate reads log content (status tags)
+gate_reads=$(grep -cE '(head -1|sed -n 1p|awk.*NR==1).*(red\.log|green\.log)' "$GATE" || true)
+if [ "$gate_reads" -gt 0 ]; then
+    echo "PASS: Gate validates status tags"
+    exit 0
+fi
+# Gate doesn't validate — check if SKILL.md still claims it does
+claim=$(grep -c 'quality_gate.sh. will check for its presence' "$SKILL" || true)
+if [ "$claim" -gt 0 ]; then
+    echo "FAIL: SKILL.md claims gate checks status tags (line 1137) but gate only checks file existence"
+    exit 1
+fi
+echo "PASS: SKILL.md does not claim gate checks status tags"
