+#!/bin/bash
+# Generated by Quality Playbook v1.4.0
+# Regression test for BUG-008: quality_gate.sh doesn't validate total/verified summary keys
+set -euo pipefail
+GATE="$(cd "$(dirname "$0")/.." && pwd)/quality_gate.sh"
+# Check if the summary validation section checks for "total" and "verified"
+# (excluding total_patches, total_groups which are different variables)
+checks_total=$(grep -E 'for skey in|summary.*total' "$GATE" | grep -c 'total' || true)
+checks_verified=$(grep -E 'for skey in|summary.*verified' "$GATE" | grep -c 'verified' || true)
+if [ "$checks_total" -gt 0 ] && [ "$checks_verified" -gt 0 ]; then
+    echo "PASS: quality_gate.sh validates total and verified summary keys"
+    exit 0
+fi
+echo "FAIL: quality_gate.sh summary check only validates confirmed_open, red_failed, green_failed — missing total and verified"
+exit 1
