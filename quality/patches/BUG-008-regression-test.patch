+
+# BUG-008: quality_gate.sh crashes on macOS bash 3.2 with no arguments
+# Spec basis: quality_gate.sh lines 25-27 specify exit 1 for no-args usage.
+# The script should print usage and exit 1, not crash with "unbound variable".
+test_bug_008_bash32_empty_array_crash() {
+    # Simulate the exact code path: set -u with empty array iteration
+    local output
+    output=$(/bin/bash -c 'set -uo pipefail; arr=(); for x in "${arr[@]}"; do echo "$x"; done; echo "OK"' 2>&1) || true
+    if echo "$output" | grep -q "unbound variable"; then
+        echo "FAIL: bash 3.2 crashes on empty array iteration with set -u"
+        echo "  Output: $output"
+        return 1
+    fi
+    return 0
+}
+
+# BUG-010: Incomplete writeups get WARN instead of FAIL
+# Spec basis: SKILL.md line 1454 says writeups are mandatory for all confirmed bugs.
+# quality_gate.sh line 561 uses warn() instead of fail() for incomplete writeups.
+test_bug_010_writeup_incomplete_warn() {
+    local line561
+    line561=$(sed -n '561p' quality_gate.sh 2>/dev/null || sed -n '561p' "${SCRIPT_DIR}/quality_gate.sh" 2>/dev/null)
+    if echo "$line561" | grep -q 'warn'; then
+        echo "FAIL: Line 561 uses warn() for incomplete writeups instead of fail()"
+        return 1
+    fi
+    return 0
+}
