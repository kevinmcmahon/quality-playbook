+#!/bin/bash
+# Generated by Quality Playbook v1.4.0
+# Regression test for BUG-002: Phase 7 not in plan overview
+set -euo pipefail
+SKILL="$(cd "$(dirname "$0")/.." && pwd)/SKILL.md"
+phase7_exists=$(grep -c '^## Phase 7:' "$SKILL" || true)
+if [ "$phase7_exists" -eq 0 ]; then
+    echo "PASS: Phase 7 removed — no inconsistency"
+    exit 0
+fi
+in_overview=$(sed -n '12,31p' "$SKILL" | grep -ci 'phase 7' || true)
+if [ "$in_overview" -gt 0 ]; then
+    echo "PASS: Phase 7 is in plan overview"
+    exit 0
+fi
+echo "FAIL: Phase 7 exists at line 1890 but not in plan overview (lines 12-31)"
+exit 1
