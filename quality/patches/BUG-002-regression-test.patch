+#!/bin/bash
+# Generated by Quality Playbook v1.4.0
+# Regression test for BUG-002: test_functional detection misses SKILL.md-allowed names
+# Spec basis: SKILL.md line 69
+
+set -uo pipefail
+SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
+REPO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
+GATE="${REPO_DIR}/quality_gate.sh"
+
+dir=$(mktemp -d)
+mkdir -p "${dir}/quality/code_reviews" "${dir}/quality/spec_audits"
+q="${dir}/quality"
+
+echo -e "# BUGS\nNo confirmed bugs. 0 confirmed bugs." > "${q}/BUGS.md"
+echo -e "# REQUIREMENTS\n\n### UC-01: T\n### UC-02: T\n### UC-03: T\n### UC-04: T\n### UC-05: T" > "${q}/REQUIREMENTS.md"
+echo "# QUALITY" > "${q}/QUALITY.md"
+echo -e "# PROGRESS\nSkill version: 1.4.0\n\n## Terminal Gate Verification" > "${q}/PROGRESS.md"
+echo "# COVERAGE" > "${q}/COVERAGE_MATRIX.md"
+echo "# COMPLETENESS" > "${q}/COMPLETENESS_REPORT.md"
+echo "# CONTRACTS" > "${q}/CONTRACTS.md"
+echo "# R" > "${q}/RUN_CODE_REVIEW.md" "${q}/RUN_SPEC_AUDIT.md" "${q}/RUN_INTEGRATION_TESTS.md" "${q}/RUN_TDD_TESTS.md"
+echo "# Review" > "${q}/code_reviews/review.md"
+echo "# Triage" > "${q}/spec_audits/triage.md"
+echo "# Auditor" > "${q}/spec_audits/auditor-1.md"
+echo '#!/bin/bash' > "${q}/spec_audits/triage_probes.sh"
+cp "${REPO_DIR}/SKILL.md" "${dir}/"
+# Use FunctionalTest.java instead of test_functional.*
+echo "public class FunctionalTest {}" > "${q}/FunctionalTest.java"
+
+output=$(bash "${GATE}" "$dir" 2>&1 || true)
+rm -rf "$dir"
+
+if echo "$output" | grep -qi "WARN.*test_functional.*missing\|FAIL.*functional test"; then
+    echo "FAIL: Gate does not detect FunctionalTest.java as a valid functional test file"
+    exit 1
+else
+    echo "PASS: Gate correctly detects FunctionalTest.java"
+    exit 0
+fi
