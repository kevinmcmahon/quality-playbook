+test_bug_012_orig_file_in_references() {
+    # BUG-012: review_protocols.md.orig in references/ is undocumented
+    # [Spec basis: SKILL.md lines 2075-2083 list reference files; .orig not among them]
+    # Expected: references/ contains only documented reference files
+    # Actual (bug): .orig backup present, will be read by agents
+    local ref_dir="${REPO_DIR}/references"
+    local orig_file="${ref_dir}/review_protocols.md.orig"
+
+    if [ -f "$orig_file" ]; then
+        # Check that the .orig file is NOT listed in SKILL.md reference table
+        if grep -q 'review_protocols.md.orig' "${REPO_DIR}/SKILL.md" 2>/dev/null; then
+            pass "BUG-012: .orig file is documented in SKILL.md"
+        else
+            xfail "BUG-012: review_protocols.md.orig exists in references/ but is not documented in SKILL.md"
+        fi
+    else
+        pass "BUG-012: No .orig file in references/"
+    fi
+}
