--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -0,0 +1,47 @@
+# Regression test for BUG-015: integration-results.json schema_version not validated
+# The gate checks tdd-results.json schema_version is "1.1" but does not check
+# integration-results.json schema_version value at all.
+
+test_bug_015_integration_schema_version_not_checked() {
+    # Setup: create a minimal valid quality directory
+    local tmpdir
+    tmpdir=$(mktemp -d)
+    local q="${tmpdir}/quality"
+    mkdir -p "${q}/results" "${q}/code_reviews" "${q}/spec_audits" "${q}/patches" "${q}/writeups"
+
+    # Create required artifacts
+    for f in BUGS.md REQUIREMENTS.md QUALITY.md PROGRESS.md COVERAGE_MATRIX.md COMPLETENESS_REPORT.md \
+             CONTRACTS.md RUN_CODE_REVIEW.md RUN_SPEC_AUDIT.md RUN_INTEGRATION_TESTS.md RUN_TDD_TESTS.md; do
+        echo "# ${f}" > "${q}/${f}"
+    done
+    echo "### BUG-001: test bug" >> "${q}/BUGS.md"
+    echo "## Terminal Gate Verification" >> "${q}/PROGRESS.md"
+    echo "Skill version: 1.4.0" >> "${q}/PROGRESS.md"
+    touch "${q}/test_functional.sh"
+    echo "# review" > "${q}/code_reviews/2026-04-15-review.md"
+    echo "# triage" > "${q}/spec_audits/2026-04-15-triage.md"
+    echo "# auditor" > "${q}/spec_audits/2026-04-15-auditor-1.md"
+    echo "# probes" > "${q}/spec_audits/triage_probes.sh"
+
+    # Create a valid tdd-results.json
+    cat > "${q}/results/tdd-results.json" <<'TDDJSON'
+{"schema_version":"1.1","skill_version":"1.4.0","date":"2026-04-15","project":"test","bugs":[{"id":"BUG-001","requirement":"UC-01","red_phase":"fail","green_phase":"pass","verdict":"TDD verified","fix_patch_present":true,"writeup_path":"quality/writeups/BUG-001.md"}],"summary":{"total":1,"verified":1,"confirmed_open":0,"red_failed":0,"green_failed":0}}
+TDDJSON
+    echo "RED" > "${q}/results/BUG-001.red.log"
+    echo "GREEN" > "${q}/results/BUG-001.green.log"
+    touch "${q}/patches/BUG-001-regression-test.patch"
+    touch "${q}/patches/BUG-001-fix.patch"
+    printf '## Summary\n\n```diff\n--- a/test\n+++ b/test\n```\n' > "${q}/writeups/BUG-001.md"
+
+    # Create integration-results.json with WRONG schema_version
+    cat > "${q}/results/integration-results.json" <<'INTJSON'
+{"schema_version":"0.9","skill_version":"0.0.0","date":"YYYY-MM-DD","project":"test","recommendation":"SHIP","groups":[{"group":1,"name":"G1","use_cases":["UC-01"],"result":"pass","tests_passed":1,"tests_failed":0,"notes":""}],"summary":{"total_groups":1,"passed":1,"failed":0,"skipped":0},"uc_coverage":{"UC-01":"covered_pass"}}
+INTJSON
+
+    # Run the gate -- expect FAIL because schema_version is "0.9" not "1.1"
+    local output
+    output=$(bash quality_gate.sh "${tmpdir}" 2>&1)
+    local exit_code=$?
+
+    # BUG: The gate does NOT check schema_version value for integration-results.json
+    # It only checks key existence. So "0.9" passes.
+    # This test expects FAIL but gets PASS on unpatched code.
+    echo "$output" | grep -q 'FAIL.*schema_version.*0\.9' || echo "XFAIL: schema_version 0.9 not detected"
+
+    rm -rf "$tmpdir"
+}
