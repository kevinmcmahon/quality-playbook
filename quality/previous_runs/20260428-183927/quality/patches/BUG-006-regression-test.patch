@@ -0,0 +1,24 @@
+import unittest
+from pathlib import Path
+
+
+REPO_ROOT = Path(__file__).resolve().parents[1]
+
+
+class CodeReviewRegressionTests(unittest.TestCase):
+    @unittest.expectedFailure
+    def test_bug_006_bootstrap_docs_match_live_release_framing(self):
+        skill_text = (REPO_ROOT / 'SKILL.md').read_text(encoding='utf-8')
+        live_version = next(line.split(':', 1)[1].strip() for line in skill_text.splitlines() if line.startswith('  version:'))
+        for path in (REPO_ROOT / 'docs_gathered' / '01_README_project.md', REPO_ROOT / 'docs_gathered' / '29_improvement_axes_and_version_history.md'):
+            with self.subTest(path=path.name):
+                text = path.read_text(encoding='utf-8')
+                self.assertIn(live_version, text)
+                self.assertIn('reference_docs', text)
+
+
+if __name__ == '__main__':
+    unittest.main()
