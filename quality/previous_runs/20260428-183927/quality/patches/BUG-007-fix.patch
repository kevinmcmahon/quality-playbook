+def _mirror_bootstrap_docs(repo_dir: Path) -> None:
+    """Expose docs_gathered/ through reference_docs/ for direct-root bootstrap runs."""
+    reference_docs_dir = repo_dir / "reference_docs"
+    docs_gathered_dir = repo_dir / "docs_gathered"
+    if _reference_docs_plaintext(reference_docs_dir):
+        return
+    if not docs_gathered_dir.is_dir():
+        return
+    reference_docs_dir.mkdir(parents=True, exist_ok=True)
+    for path in sorted(docs_gathered_dir.iterdir()):
+        if not path.is_file() or path.suffix.lower() not in {".md", ".txt"} or path.name == "README.md":
+            continue
+        shutil.copy2(path, reference_docs_dir / path.name)
+
