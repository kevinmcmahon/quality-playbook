+from pathlib import Path
+import tempfile
+import unittest
+
+from bin import run_playbook
+
+
+class CodeReviewRegressionTests(unittest.TestCase):
+    @unittest.expectedFailure
+    def test_bug_002_phase2_gate_enforces_written_contract(self):
+        """BUG-002: malformed long EXPLORATION.md files must fail Phase 2."""
+        with tempfile.TemporaryDirectory() as tmp:
+            repo = Path(tmp)
+            quality = repo / "quality"
+            quality.mkdir()
+            (quality / "EXPLORATION.md").write_text("
".join(f"line {i}" for i in range(1, 123)), encoding="utf-8")
+            self.assertFalse(run_playbook.check_phase_gate(repo, "2").ok)
+
+
+if __name__ == "__main__":
+    unittest.main()
