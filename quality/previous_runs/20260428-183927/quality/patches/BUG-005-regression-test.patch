@@ -0,0 +1,32 @@
+import os
+import shutil
+import subprocess
+import sys
+import tempfile
+import unittest
+from pathlib import Path
+
+
+REPO_ROOT = Path(__file__).resolve().parents[1]
+
+
+class CodeReviewRegressionTests(unittest.TestCase):
+    @unittest.expectedFailure
+    def test_bug_005_installed_gate_retains_citation_verifier(self):
+        with tempfile.TemporaryDirectory() as tmp:
+            install_root = Path(tmp)
+            gate_path = install_root / ".github" / "skills" / "quality_gate.py"
+            gate_path.parent.mkdir(parents=True, exist_ok=True)
+            shutil.copyfile(REPO_ROOT / ".github" / "skills" / "quality_gate" / "quality_gate.py", gate_path)
+            probe = "import importlib.util, pathlib, sys; path = pathlib.Path(sys.argv[1]); spec = importlib.util.spec_from_file_location('installed_quality_gate', path); mod = importlib.util.module_from_spec(spec); spec.loader.exec_module(mod); print('present' if mod._CITATION_VERIFIER is not None else 'missing')"
+            env = os.environ.copy()
+            env['PYTHONPATH'] = str(install_root)
+            result = subprocess.run([sys.executable, '-c', probe, str(gate_path)], cwd=install_root, env=env, capture_output=True, text=True, check=True)
+            self.assertEqual(result.stdout.strip(), 'present')
+
+
+if __name__ == '__main__':
+    unittest.main()
