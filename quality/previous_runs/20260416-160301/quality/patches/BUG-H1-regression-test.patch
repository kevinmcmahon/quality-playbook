+#!/bin/bash
+# Generated by Quality Playbook v1.4.1 — https://github.com/andrewstellman/quality-playbook
+# Author: Andrew Stellman · Date: 2026-04-16 · Project: quality-playbook
+#
+# Regression tests for confirmed bugs.
+# Skip guards: each test function checks for BUG_SKIP_NNN env var.
+# To run a specific test against unpatched code (red phase):
+#   BUG_SKIP_H1=0 bash quality/test_regression.sh test_BUG_H1_json_has_key_false_positive
+# All tests are skip-guarded by default to avoid failing CI before fixes land.
+
+set -uo pipefail
+
+PASS=0
+FAIL=0
+SKIP=0
+
+run_test() {
+    local name="$1"
+    echo "  TEST: $name"
+    if "$name"; then
+        echo "  RESULT: PASS"
+        PASS=$((PASS + 1))
+    else
+        echo "  RESULT: FAIL"
+        FAIL=$((FAIL + 1))
+    fi
+}
+
+# ---------------------------------------------------------------------------
+# BUG-H1: json_has_key matches keys inside string values (false positive)
+#
+# The bug: json_has_key uses `grep -q "\"key\""` without requiring a colon.
+# A JSON file where "id" appears only inside a string value returns true.
+# Skip guard: set BUG_SKIP_H1=0 to enable (default: skip)
+# Remove this guard and re-run after applying quality/patches/BUG-H1-fix.patch
+# ---------------------------------------------------------------------------
+test_BUG_H1_json_has_key_false_positive() {
+    if [ "${BUG_SKIP_H1:-1}" = "1" ]; then
+        echo "  SKIP: BUG-H1 skip guard active (set BUG_SKIP_H1=0 to run)"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    # Create a JSON file where "id" appears only inside a string value, NOT as a key
+    local tmpfile
+    tmpfile=$(mktemp /tmp/bug_h1_test.XXXXXX.json)
+    cat > "$tmpfile" <<'EOF'
+{
+  "message": "the id field is required",
+  "schema_version": "1.1"
+}
+EOF
+
+    # Source the helper function from quality_gate.sh
+    json_has_key() {
+        local file="$1" key="$2"
+        grep -q "\"${key}\"" "$file" 2>/dev/null
+    }
+
+    # Expected: json_has_key "id" should return false (1) because "id" is not a key
+    # Bug behavior: returns true (0) because "id" appears inside the string value
+    if json_has_key "$tmpfile" "id"; then
+        # Bug is present — json_has_key returned true for a non-key occurrence
+        echo "  BUG CONFIRMED: json_has_key returned true for 'id' in string value"
+        rm -f "$tmpfile"
+        return 1  # Test FAILS (as expected on unpatched code — this is the red phase)
+    else
+        # Bug is fixed — json_has_key correctly returned false
+        rm -f "$tmpfile"
+        return 0  # Test PASSES (correct behavior)
+    fi
+}
+
+# Run tests
+echo "=== Regression Tests: quality-playbook ==="
+if [ $# -gt 0 ]; then
+    # Run specific test by name
+    run_test "$1"
+else
+    run_test test_BUG_H1_json_has_key_false_positive
+fi
+
+echo ""
+echo "Results: ${PASS} PASS, ${FAIL} FAIL, ${SKIP} SKIP"
+[ "$FAIL" -eq 0 ]
