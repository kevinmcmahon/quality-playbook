--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -0,0 +1,28 @@
+# BUG-L19: Summary sub-key check uses json_has_key (weak) instead of json_key_count (strong)
+# Regression test: confirms that quality_gate.sh:259-265 uses json_has_key for summary key checks
+# while the parallel per-bug field check at lines 239-248 uses the stronger json_key_count.
+#
+: "${BUG_SKIP_L19:=1}"
+test_BUG_L19_summary_check_uses_weak_json_has_key() {
+    if [ "$BUG_SKIP_L19" -ne 0 ]; then
+        echo "SKIP: test_BUG_L19_summary_check_uses_weak_json_has_key"
+        return 77
+    fi
+    echo "TEST: test_BUG_L19_summary_check_uses_weak_json_has_key"
+    local gate="quality_gate.sh"
+    local summary_check_pattern
+    summary_check_pattern=$(grep -n 'json_has_key.*json_file.*skey\|skey.*json_has_key' "$gate" | head -5)
+    if [ -n "$summary_check_pattern" ]; then
+        echo "  BUG CONFIRMED: json_has_key used for summary sub-key checks"
+        echo "  Per-bug check uses json_key_count (stronger); inconsistency confirmed"
+        return 1
+    else
+        echo "  BUG FIXED: summary check now uses json_key_count consistently"
+        return 0
+    fi
+}
