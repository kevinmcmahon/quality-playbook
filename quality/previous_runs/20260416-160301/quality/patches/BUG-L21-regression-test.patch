--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -0,0 +1,32 @@
+# BUG-L21: Phase 5 has no entry gate for Phase 4 artifacts (spec bug)
+# Regression test: confirms SKILL.md has Phase 2 entry gate but no Phase 5 entry gate.
+# Phase 2: "Phase 2 entry gate (mandatory — HARD STOP)" fires BEFORE Phase 2 work
+# Phase 5: no equivalent entry gate — only terminal gate at the END of Phase 5
+#
+: "${BUG_SKIP_L21:=1}"
+test_BUG_L21_phase5_no_entry_gate() {
+    if [ "$BUG_SKIP_L21" -ne 0 ]; then
+        echo "SKIP: test_BUG_L21_phase5_no_entry_gate"
+        return 77
+    fi
+    echo "TEST: test_BUG_L21_phase5_no_entry_gate"
+    local skill_md="SKILL.md"
+    local phase2_gate
+    phase2_gate=$(grep -n 'Phase 2 entry gate.*mandatory.*HARD STOP' "$skill_md" | head -1)
+    local phase5_gate
+    phase5_gate=$(grep -n 'Phase 5 entry gate\|Phase 5.*entry gate.*mandatory' "$skill_md" | head -1)
+    if [ -n "$phase2_gate" ] && [ -z "$phase5_gate" ]; then
+        echo "  BUG CONFIRMED: Phase 2 has entry gate but Phase 5 has none"
+        echo "  Phase 2: $phase2_gate"
+        echo "  Phase 5: [no entry gate found]"
+        return 1
+    elif [ -n "$phase5_gate" ]; then
+        echo "  BUG FIXED: Phase 5 entry gate found: $phase5_gate"
+        return 0
+    else
+        echo "  INCONCLUSIVE: Phase 2 gate text not found"
+        return 1
+    fi
+}
