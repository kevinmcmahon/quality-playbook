     fi
 }

+# ---------------------------------------------------------------------------
+# BUG-L6: json_str_val returns empty for non-string values, misleading errors
+#
+# The bug: json_str_val() requires a quoted value. For "schema_version": 1.1,
+# the function returns "" which the caller reports as "missing" not "wrong type."
+# Skip guard: set BUG_SKIP_L6=0 to enable (default: skip)
+# Remove this guard after applying quality/patches/BUG-L6-fix.patch
+# ---------------------------------------------------------------------------
+test_BUG_L6_json_str_val_non_string_empty() {
+    if [ "${BUG_SKIP_L6:-1}" = "1" ]; then
+        echo "  SKIP: BUG-L6 skip guard active (set BUG_SKIP_L6=0 to run)"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    # Define the current (buggy) json_str_val implementation
+    json_str_val_buggy() {
+        local file="$1" key="$2"
+        grep -o "\"${key}\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "$file" 2>/dev/null \
+            | head -1 | sed 's/.*: *"\([^"]*\)"/\1/'
+    }
+
+    local tmpfile
+    tmpfile=$(mktemp /tmp/bug_l6_test.XXXXXX.json)
+
+    # JSON with schema_version as a number (not a string)
+    cat > "$tmpfile" <<'EOF'
+{
+  "schema_version": 1.1,
+  "skill_version": "1.4.1"
+}
+EOF
+
+    local result
+    result=$(json_str_val_buggy "$tmpfile" "schema_version")
+
+    rm -f "$tmpfile"
+
+    # Bug behavior: result is empty ("") because the regex requires a quoted value
+    # Fixed behavior: result should be some sentinel value indicating "key exists, non-string"
+    if [ -z "$result" ]; then
+        # Bug is present — returned empty for a number value
+        echo "  BUG CONFIRMED: json_str_val returned empty for number-typed schema_version"
+        echo "  Caller would report: \"schema_version is 'missing'\" — misleading (key exists as number)"
+        return 1  # Test FAILS on unpatched code (red phase)
+    else
+        # Bug is fixed — returned a non-empty sentinel
+        echo "  BUG FIXED: json_str_val returned '${result}' for number-typed schema_version (not empty)"
+        return 0
+    fi
+}
+
 # Run tests
 echo "=== Regression Tests: quality-playbook ==="
