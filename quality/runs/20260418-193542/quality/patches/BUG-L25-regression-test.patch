--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -0,0 +1,36 @@
+# BUG-L25: Phase 2 entry gate omits Phase 1 completion gate check #1 (120-line minimum)
+# Regression test: confirms SKILL.md:850 has 120-line check in Phase 1 completion gate
+# but SKILL.md:897-904 (Phase 2 entry gate) does NOT include this check.
+# BUG-M3 fix adds checks 2,3,5,8,10,12 but NOT check #1.
+#
+: "${BUG_SKIP_L25:=1}"
+test_BUG_L25_phase2_entry_gate_missing_check1() {
+    if [ "$BUG_SKIP_L25" -ne 0 ]; then
+        echo "SKIP: test_BUG_L25_phase2_entry_gate_missing_check1"
+        return 77
+    fi
+    echo "TEST: test_BUG_L25_phase2_entry_gate_missing_check1"
+    local skill_md="SKILL.md"
+    # Verify Phase 1 completion gate has the 120-line check
+    local phase1_120_check
+    phase1_120_check=$(grep -n '120' "$skill_md" | grep -i 'line\|substan\|content' | head -5)
+    # Check Phase 2 entry gate section (lines 897-920 approx) for 120-line check
+    local phase2_120_check
+    phase2_120_check=$(awk 'NR>=890 && NR<=940' "$skill_md" | grep '120')
+    if [ -n "$phase1_120_check" ] && [ -z "$phase2_120_check" ]; then
+        echo "  BUG CONFIRMED: Phase 1 gate has 120-line check, Phase 2 entry gate does NOT"
+        echo "  Phase 1 check #1 at: $phase1_120_check"
+        echo "  Phase 2 entry gate (lines 890-940): no 120-line minimum check found"
+        echo "  After BUG-M3 fix: thin EXPLORATION.md (~15 lines) still passes Phase 2 entry gate"
+        echo "  BUG-M3 fix adds checks 2,3,5,8,10,12 but omits check #1 (120-line minimum)"
+        return 1
+    elif [ -n "$phase2_120_check" ]; then
+        echo "  BUG FIXED: Phase 2 entry gate now includes 120-line check: $phase2_120_check"
+        return 0
+    else
+        echo "  INCONCLUSIVE: Phase 1 check #1 (120-line) not found at expected location"
+        return 1
+    fi
+}
