--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -0,0 +1,40 @@
+# ---------------------------------------------------------------------------
+# BUG-M16: functional test existence check uses ls-glob (nullglob vulnerable)
+# ---------------------------------------------------------------------------
+: "${BUG_SKIP_M16:=1}"
+test_BUG_M16_functional_test_existence_nullglob() {
+    if [ "$BUG_SKIP_M16" -ne 0 ]; then
+        echo "SKIP: test_BUG_M16_functional_test_existence_nullglob (BUG_SKIP_M16=${BUG_SKIP_M16})"
+        return 77
+    fi
+    echo "TEST: test_BUG_M16_functional_test_existence_nullglob"
+    local gate="/Users/andrewstellman/tmp/QFB-bootstrap/quality_gate.sh"
+    # The bug: line 124 uses ls-glob, not find-based detection
+    # A find-based check would look like: find "${q}" -maxdepth 1 -name "test_functional.*" -print -quit | grep -q .
+    # The vulnerable pattern: if ls ${q}/test_functional.* ...
+    if grep -qE 'if ls \$\{q\}/test_functional\.' "$gate"; then
+        echo "  BUG CONFIRMED: quality_gate.sh:124 uses ls-glob for functional test existence (nullglob vulnerable)"
+        return 1  # FAILS on unpatched code (red phase)
+    elif grep -qE 'find.*test_functional.*print.*quit.*grep -q' "$gate" || \
+         grep -n 'test_functional' "$gate" | grep -q 'find'; then
+        echo "  BUG FIXED: quality_gate.sh now uses find-based functional test existence check"
+        return 0
+    else
+        echo "  INDETERMINATE: cannot confirm presence of ls-glob or find-based check at line 124"
+        return 2
+    fi
+}
+
+# Add to run_test calls (in else branch):
+#    run_test test_BUG_M16_functional_test_existence_nullglob

Rationale: quality_gate.sh:124 uses `ls ${q}/test_functional.*` which under nullglob
(zsh default on macOS, or bash with nullglob set) expands to no arguments and ls
lists the current working directory, always succeeding. The gate reports
"PASS: functional test file exists" when no test file is present.
The fix replaces the ls-glob with find-based detection, matching the correct
pattern already used at lines 449-454.
