--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -0,0 +1,28 @@
+# BUG-L20: Patch existence uses aggregate count instead of per-bug iteration
+# Regression test: confirms that quality_gate.sh:562-588 uses aggregate ls-glob count
+# while the parallel TDD log check at lines 316-345 iterates per bug ID (correct pattern).
+#
+: "${BUG_SKIP_L20:=1}"
+test_BUG_L20_patch_count_aggregate_vs_per_bug() {
+    if [ "$BUG_SKIP_L20" -ne 0 ]; then
+        echo "SKIP: test_BUG_L20_patch_count_aggregate_vs_per_bug"
+        return 77
+    fi
+    echo "TEST: test_BUG_L20_patch_count_aggregate_vs_per_bug"
+    local gate="quality_gate.sh"
+    local aggregate_patch_count
+    aggregate_patch_count=$(grep -n 'reg_patch_count=\$(ls.*patches.*BUG-\*' "$gate" | head -3)
+    if [ -n "$aggregate_patch_count" ]; then
+        echo "  BUG CONFIRMED: aggregate patch count pattern: $aggregate_patch_count"
+        echo "  Cannot detect missing patch for specific bug — only detects wrong total count"
+        return 1
+    else
+        echo "  BUG FIXED: patch check now iterates per-bug ID"
+        return 0
+    fi
+}
