--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -0,0 +1,36 @@
+# BUG-L24: integration-results.json summary sub-keys not validated
+# Regression test: confirms quality_gate.sh checks summary key PRESENCE only.
+# Sub-keys total_groups, passed, failed, skipped (SKILL.md:1252-1255) never checked.
+# Contrast: tdd-results.json summary sub-keys ARE checked at lines 259-265.
+#
+: "${BUG_SKIP_L24:=1}"
+test_BUG_L24_integration_summary_subkeys_absent() {
+    if [ "$BUG_SKIP_L24" -ne 0 ]; then
+        echo "SKIP: test_BUG_L24_integration_summary_subkeys_absent"
+        return 77
+    fi
+    echo "TEST: test_BUG_L24_integration_summary_subkeys_absent"
+    local gate="quality_gate.sh"
+    # Should find no integration summary sub-key validation
+    local int_summary_subkey_check
+    int_summary_subkey_check=$(grep -n 'total_groups\|integration.*summary\|summary.*total_groups' "$gate" | grep -v '^#' | head -5)
+    # Verify tdd summary sub-keys ARE checked (for contrast)
+    local tdd_summary_subkey_check
+    tdd_summary_subkey_check=$(grep -n 'total\|verified\|confirmed_open\|red_failed\|green_failed' "$gate" | grep -v '^#' | head -5)
+    if [ -z "$int_summary_subkey_check" ] && [ -n "$tdd_summary_subkey_check" ]; then
+        echo "  BUG CONFIRMED: integration summary sub-keys NOT validated in gate"
+        echo "  No check for total_groups, passed, failed, skipped in quality_gate.sh"
+        echo "  Contrast: tdd summary sub-keys ARE validated: $tdd_summary_subkey_check"
+        echo "  SKILL.md:1252-1255 defines 4 required summary sub-keys"
+        echo "  An integration-results.json with empty summary{} passes gate undetected"
+        return 1
+    elif [ -n "$int_summary_subkey_check" ]; then
+        echo "  BUG FIXED: integration summary sub-key validation now present: $int_summary_subkey_check"
+        return 0
+    else
+        echo "  INCONCLUSIVE: tdd summary sub-key checks not found — gate structure may have changed"
+        return 1
+    fi
+}
