--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -0,0 +1,44 @@
+# ---------------------------------------------------------------------------
+# BUG-M18: TDD sidecar JSON phase values not cross-validated against log tags
+# ---------------------------------------------------------------------------
+: "${BUG_SKIP_M18:=1}"
+test_BUG_M18_red_phase_log_cross_validation() {
+    if [ "$BUG_SKIP_M18" -ne 0 ]; then
+        echo "SKIP: test_BUG_M18_red_phase_log_cross_validation (BUG_SKIP_M18=${BUG_SKIP_M18})"
+        return 77
+    fi
+    echo "TEST: test_BUG_M18_red_phase_log_cross_validation"
+    local gate="/Users/andrewstellman/tmp/QFB-bootstrap/quality_gate.sh"
+    # The cross-validation that MUST exist per SKILL.md:1589:
+    #   Extract json_str_val for "red_phase", compare with first line of BUG-NNN.red.log
+    # Proxy: look for code that reads red_phase VALUE (not just checks key presence)
+    # json_key_count checks presence; json_str_val extracts value
+    # Cross-validation would combine json_str_val "red_phase" with comparison against log tag
+    local has_cross_val=0
+    # Check for a pattern that extracts red_phase value AND compares with log tag
+    if grep -A5 'red_phase\|green_phase' "$gate" | grep -q 'json_str_val'; then
+        has_cross_val=1
+    fi
+    if grep -q 'red_phase.*red_tag\|red_tag.*red_phase\|green_phase.*green_tag\|green_tag.*green_phase' "$gate"; then
+        has_cross_val=1
+    fi
+    if [ "$has_cross_val" -eq 0 ]; then
+        echo "  BUG CONFIRMED: no cross-validation between tdd-results.json phase values and log tags"
+        echo "  SKILL.md:1589 mandates: if red_phase='pass' in JSON, BUG-NNN.red.log first line must be RED"
+        echo "  Gate validates field presence (lines 239-248) and tag format (lines 322-325) independently"
+        echo "  But never compares them — contradiction between JSON and log goes undetected"
+        return 1  # FAILS on unpatched code (red phase)
+    else
+        echo "  BUG FIXED: cross-validation between sidecar JSON phase values and log tags is present"
+        return 0
+    fi
+}
+
+# Add to run_test calls (in else branch):
+#    run_test test_BUG_M18_red_phase_log_cross_validation

Rationale: SKILL.md:1589 mandates "TDD sidecar-to-log consistency check (mandatory)."
The gate (lines 239-248) checks JSON field presence only. The gate (lines 307-387)
checks log file tag format only. Neither section ever compares a JSON phase value
against the corresponding log tag. An agent can write "verdict": "TDD verified"
with a contradicting log (e.g., green.log says GREEN when it should say RED for
a bug that wasn't actually reproduced) and the gate will pass without detection.
Note: BUG-M18 has no fix patch — the fix requires writing a new validation section
in quality_gate.sh that calls json_str_val for each bug's red_phase and green_phase
and compares against the corresponding log file first line. This is a substantial
new code section and the spec (SKILL.md:1589) already describes the required logic.
