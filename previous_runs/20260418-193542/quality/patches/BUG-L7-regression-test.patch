+# ---------------------------------------------------------------------------
+# BUG-L7: Version number hardcoded in multiple SKILL.md locations
+#
+# The bug: SKILL.md contains 1.4.1 in 8+ locations with no mechanical
+# cross-reference check. A version bump that updates frontmatter but misses
+# one inline occurrence would not be detected by any tool.
+# This test verifies all occurrences match the frontmatter version.
+# Skip guard: set BUG_SKIP_L7=0 to enable (default: skip)
+# No fix patch exists — fix is adding a grep check to CI or quality_gate.sh
+# ---------------------------------------------------------------------------
+test_BUG_L7_version_string_consistency() {
+    if [ "${BUG_SKIP_L7:-1}" = "1" ]; then
+        echo "  SKIP: BUG-L7 skip guard active (set BUG_SKIP_L7=0 to run)"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    local skill_md="${SKILL_MD_PATH:-SKILL.md}"
+
+    if [ ! -f "$skill_md" ]; then
+        echo "  SKIP: SKILL.md not found at $skill_md (set SKILL_MD_PATH)"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    # Extract frontmatter version
+    local frontmatter_version
+    frontmatter_version=$(grep -m1 'version:' "$skill_md" | sed 's/.*version: *//' | tr -d ' ')
+
+    if [ -z "$frontmatter_version" ]; then
+        echo "  SKIP: Could not extract frontmatter version from SKILL.md"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    # Find all version-like strings in SKILL.md (X.Y.Z pattern)
+    # Count those that differ from frontmatter version
+    local all_versions stale_versions
+    all_versions=$(grep -oE '[0-9]+\.[0-9]+\.[0-9]+' "$skill_md" | sort -u)
+    stale_versions=$(echo "$all_versions" | grep -v "^${frontmatter_version}$" || true)
+
+    if [ -n "$stale_versions" ]; then
+        echo "  BUG CONFIRMED: Found version strings in SKILL.md that differ from frontmatter '${frontmatter_version}':"
+        echo "$stale_versions" | while read -r v; do
+            local count linenos
+            count=$(grep -c "$v" "$skill_md" || true)
+            linenos=$(grep -n "$v" "$skill_md" | awk -F: '{printf "%s ", $1}' | sed 's/ $//')
+            echo "    - '$v' at $count location(s): lines $linenos"
+        done
+        return 1  # Test FAILS when stale versions exist
+    else
+        echo "  All version strings in SKILL.md match frontmatter '${frontmatter_version}'"
+        # The bug is the ABSENCE of a mechanical check, not current inconsistency.
+        # Current state is consistent, but the test passing here is not evidence the
+        # bug is fixed — it means the current versions happen to all match.
+        # The fix requires adding this check to quality_gate.sh or CI.
+        echo "  NOTE: No mechanical check enforces this — BUG-L7 latent risk remains until"
+        echo "        this test (or equivalent) is integrated into quality_gate.sh"
+        return 0
+    fi
+}
+
 # Run tests
 echo "=== Regression Tests: quality-playbook ==="
