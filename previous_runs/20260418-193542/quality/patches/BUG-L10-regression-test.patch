 }

+# ---------------------------------------------------------------------------
+# BUG-L10: Recheck mode uses schema_version "1.0" while all other sidecars use "1.1"
+#
+# The bug: SKILL.md recheck template (line 1965) specifies schema_version "1.0"
+# while tdd-results.json (line 128) and integration-results.json (line 156)
+# use schema_version "1.1". No migration note explains the discrepancy.
+# [BUG from Phase 4 Spec Audit — Auditors A and B]
+# Skip guard: set BUG_SKIP_L10=0 to enable
+# Fix: (no patch — fix is updating recheck template or documenting the intent)
+# ---------------------------------------------------------------------------
+test_BUG_L10_recheck_schema_version_inconsistency() {
+    if [ "${BUG_SKIP_L10:-1}" = "1" ]; then
+        echo "  SKIP: BUG-L10 skip guard active (set BUG_SKIP_L10=0 to run red phase)"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    local skill_md="${SKILL_MD_PATH:-SKILL.md}"
+
+    if [ ! -f "$skill_md" ]; then
+        echo "  SKIP: SKILL.md not found"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    # BUG CONFIRMATION: Both schema versions exist in SKILL.md
+    local recheck_schema
+    recheck_schema=$(grep -n '"schema_version": "1\.0"' "$skill_md" | head -1)
+    local main_schema
+    main_schema=$(grep -n '"schema_version": "1\.1"' "$skill_md" | head -1)
+
+    if [ -n "$recheck_schema" ] && [ -n "$main_schema" ]; then
+        echo "  BUG CONFIRMED: SKILL.md contains both schema_version '1.0' and '1.1'"
+        echo "  Recheck template (1.0): $recheck_schema"
+        echo "  TDD/integration template (1.1): $main_schema"
+        echo "  No migration note explains the version discrepancy"
+        return 1  # FAILS on unpatched code (red phase)
+    else
+        echo "  BUG FIXED: schema versions unified (or recheck schema updated)"
+        return 0
+    fi
+}
+
 # ---------------------------------------------------------------------------
 # Run tests
 # ---------------------------------------------------------------------------
@@ -727,6 +780,7 @@ else
     run_test test_BUG_L9_auditor_naming_inconsistency
+    run_test test_BUG_L10_recheck_schema_version_inconsistency
 fi
