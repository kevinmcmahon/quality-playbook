--- a/quality/test_regression.sh
+++ b/quality/test_regression.sh
@@ -623,6 +623,40 @@ test_BUG_L11_tdd_results_two_incompatible_templates() {
     fi
 }

+# ---------------------------------------------------------------------------
+# BUG-M12: ls-glob in test file extension detection (quality_gate.sh:479)
+#
+# The bug: `func_test=$(ls ${q}/test_functional.* 2>/dev/null | head -1)` uses
+# ls-glob pattern vulnerable to nullglob: under zsh nullglob, unmatched glob
+# expands to empty causing ls to list CWD, returning a wrong filename.
+# The correct fix: use find-based detection (already used 7 lines later at :486).
+# [BUG from Gap Iteration Spec Audit — 2026-04-16]
+# Skip guard: set BUG_SKIP_M12=0 to enable
+# Fix: quality/patches/BUG-M12-fix.patch
+# ---------------------------------------------------------------------------
+test_BUG_M12_test_file_ext_ls_glob_false_positive() {
+    if [ "${BUG_SKIP_M12:-1}" = "1" ]; then
+        echo "  SKIP: BUG-M12 skip guard active (set BUG_SKIP_M12=0 to run red phase)"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    local gate="${GATE_SH_PATH:-quality_gate.sh}"
+
+    if [ ! -f "$gate" ]; then
+        echo "  SKIP: quality_gate.sh not found"
+        SKIP=$((SKIP + 1))
+        return 0
+    fi
+
+    # BUG CONFIRMATION: line 479 uses ls-glob instead of find
+    if grep -qE 'func_test=\$\(ls [^)]*test_functional\.\*' "$gate"; then
+        echo "  BUG CONFIRMED: quality_gate.sh uses ls-glob for func_test assignment (vulnerable to nullglob)"
+        return 1  # FAILS on unpatched code (red phase)
+    else
+        echo "  BUG FIXED: func_test assignment uses find-based detection"
+        return 0
+    fi
+}
+
 # ---------------------------------------------------------------------------
 # Run tests
 # ---------------------------------------------------------------------------
@@ -647,5 +681,6 @@ else
     run_test test_BUG_L10_recheck_schema_version_inconsistency
     run_test test_BUG_L11_tdd_results_two_incompatible_templates
+    run_test test_BUG_M12_test_file_ext_ls_glob_false_positive
 fi
