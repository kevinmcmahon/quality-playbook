# Local skill installations (test copies, not the canonical source)
.github/

# Claude Code local settings (session-specific permissions, not part of the skill)
.claude/

# Test repos and run artifacts (used for playbook evaluation, not part of the skill)
repos/

# docs_gathered/ is NEVER tracked — it contains AI chat history and other
# private reference material that must not be published. This rule applies at
# every depth (root-level bootstrap docs AND any repos/*/docs_gathered/).
docs_gathered/
**/docs_gathered/

# Bootstrap self-audit run history — TRACKED as project history:
#   quality/          self-audit output (proof of work)
#   previous_runs/    archived prior runs (iteration evidence)
#   control_prompts/  per-phase prompts sent to the runner
#   *-playbook-*.log  per-run logs
# cleanup_repo protects these paths from `git checkout .` via PROTECTED_PREFIXES,
# so they are safe to track.

# Python artifacts
__pycache__/
*.pyc
.venv/

# Parallel runner PID files (one per parent process — .run_pids.<pid>)
.run_pids
.run_pids.*

# OS artifacts
.DS_Store
Thumbs.db

# Editor artifacts
*.swp
*.swo
*~

# Council review artifacts (prompts, responses, briefings)
council-reviews/

# Pattern discovery working files
pattern-discovery/
